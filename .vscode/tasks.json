{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "cmake",
			"label": "CMake: build",
			"command": "build",
			"targets": [
				"all"
			],
			"preset": "__defaultBuildPreset__",
			"group": {
                "kind": "build",
                "isDefault": true
            },
			"problemMatcher": [],
			"detail": "CMake template build task"
		},
		{
			"type": "shell",
			"label": "generate erpc",
			"command": "./erpc/build/erpcgen/erpcgen --output generated interface.erpc",
			"group": {
                "kind": "build",
                "isDefault": true
            }
		},
		{
			"label": "Copy eRPC generated files",
			"type": "shell",
			"command": "cp -r -f generated/* ../Nucleo_F439ZI/src/erpc_generated/",
			"group": {
                "kind": "build",
                "isDefault": true
            }
		}
	]
}